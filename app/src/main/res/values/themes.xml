<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GymApp" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Default Splash Screen background (Android 11 and below) -->
        <item name="android:windowBackground">@color/black</item>
    </style>

    <!-- Splash Screen theme for Android 12+ -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <!-- Using mipmap icon which is better supported as a starting icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.GymApp</item>
    </style>
</resources>